<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.CALL_SCREENING" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.termux" />
    </queries>

    <application
        android:name="com.checkmate.CheckmateApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Checkmate"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name="com.checkmate.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Regular foreground services -->
        <service android:name="com.checkmate.service.FloatingAttentionService"
            android:exported="false" android:foregroundServiceType="dataSync" />
        <!-- mediaProjection type added so Android 14+ allows getMediaProjection() while this service is running -->
        <service android:name="com.checkmate.service.AttentionCycleService"
            android:exported="false" android:foregroundServiceType="dataSync|mediaProjection" />
        <service android:name="com.checkmate.service.ReminderService"
            android:exported="false" android:foregroundServiceType="dataSync" />
        <service android:name="com.checkmate.service.WhatsAppReportService"
            android:exported="false" android:foregroundServiceType="dataSync" />
        <service android:name="com.checkmate.workmode.WorkModeService"
            android:exported="false" android:foregroundServiceType="dataSync" />

        <!-- Call screening service -->
        <service android:name="com.checkmate.callhandler.CheckmateCallScreeningService"
            android:permission="android.permission.BIND_SCREENING_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <service
            android:name="com.checkmate.callhandler.CallAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/call_accessibility_config" />
        </service>

        <service
            android:name="com.checkmate.automation.AppAutomationService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <service android:name="com.checkmate.automation.WhatsAppNotificationListener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true"
            android:process=":wa_listener">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Device Admin — hides the plain Uninstall button on Checkmate's App Info
             screen once activated. Activation is a user action from Settings →
             Security tile (SettingsScreen.kt), not forced at install time. -->
        <receiver
            android:name="com.checkmate.admin.CheckmateDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Reschedules guardian alarms (EOD summary, 30-min usage report) after
             reboot, since AlarmManager repeating alarms don't survive a restart.
             Also fires a one-time Safe Mode notice to the guardian if relevant. -->
        <receiver
            android:name="com.checkmate.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Fires at the two hardcoded Work Mode schedule boundaries (19:00
             and 02:00 daily) so the forced block window is reconciled even
             while the phone is idle with Checkmate's UI closed. Registered
             here (not :workmode's manifest) to match how every other
             cross-module component in this app is declared. -->
        <receiver
            android:name="com.checkmate.workmode.WorkModeScheduleReceiver"
            android:exported="false" />

        <receiver android:name="com.checkmate.service.EodSummaryReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.checkmate.EOD_SUMMARY" />
            </intent-filter>
        </receiver>

        <!-- Fires every 30 min: pushes app-usage Telegram alert + caches it
             in the worker's KV for the on-demand "usage" command -->
        <receiver android:name="com.checkmate.service.UsageReportReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.checkmate.USAGE_REPORT" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.checkmate.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
