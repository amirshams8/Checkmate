<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimal device-admin policy set. We don't need password/camera/wipe
    policies — activation alone is what hides the plain Uninstall button
    on Checkmate's App Info screen. Keeping this list empty avoids scary
    permission text in the activation dialog ("can erase your data", etc).
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
    </uses-policies>
</device-admin>
