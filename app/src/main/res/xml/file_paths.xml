<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
        Exposes files/screenshots/ inside app's internal storage.
        Authority must match android:authorities in AndroidManifest.xml.
        WhatsApp reads content:// URIs with FLAG_GRANT_READ_URI_PERMISSION.
    -->
    <files-path
        name="screenshots"
        path="screenshots/" />
</paths>
